---
import { NAV_LINKS, SITE, SOCIAL_LINKS } from "@utils/constants";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={`${SITE.base}/`} class="footer-logo" aria-label={`${SITE.title}, Home`}>
          <span class="logo-mark" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 32 32">
              <path d="M6 6.5 L13 6.5 L16 15 Z" fill="#0B1F3A"></path>
              <path d="M26 6.5 L19 6.5 L16 15 Z" fill="#0B1F3A"></path>
              <path d="M16 15 L22 21 L16 27 L10 21 Z" fill="#0B1F3A"></path>
            </svg>
          </span>
          <span>{SITE.title}</span>
        </a>
        <p class="footer-tagline">
          Global Business Operations & Market Enablement: Latin America & Caribbean.
        </p>
      </div>

      <nav aria-label="Footer navigation" class="footer-nav">
        <h2 class="footer-heading">Navigation</h2>
        <ul role="list">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="footer-connect">
        <h2 class="footer-heading">Connect</h2>
        <ul role="list" class="social-list">
          <li>
            <a
              href={SOCIAL_LINKS.linkedin}
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a href={SOCIAL_LINKS.phone} class="footer-link">{SOCIAL_LINKS.phoneDisplay}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} {SITE.title}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: var(--border-width) solid var(--color-border);
    background-color: var(--color-bg-alt);
  }

  .footer-inner {
    padding-block: var(--space-12);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-10);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-text);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
  }

  .footer-logo:hover {
    color: var(--color-primary);
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background-color: #c89b3c;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .footer-tagline {
    margin-top: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: 30ch;
  }

  .footer-heading {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer-nav ul,
  .social-list {
    list-style: none;
    padding: 0;
  }

  .footer-nav li + li,
  .social-list li + li {
    margin-top: var(--space-2);
  }

  .footer-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: var(--border-width) solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
