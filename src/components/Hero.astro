---
interface Props {
  eyebrow?: string;
  title: string;
  valueProps?: string[];
  subtitle: string;
  badge?: string;
  cta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
}

const { eyebrow, title, valueProps, subtitle, badge, cta, secondaryCta } =
  Astro.props;
---

<section class="hero section" aria-labelledby="hero-heading">
  <div class="container">
    <div class="hero-content">
      {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
      <h1 id="hero-heading" class="hero-title" transition:name="hero-title">
        {title}
      </h1>
      {
        valueProps && valueProps.length > 0 && (
          <p class="hero-value-props">{valueProps.join("  ·  ")}</p>
        )
      }
      <p class="hero-subtitle">{subtitle}</p>
      {badge && <div class="hero-badge" role="note">{badge}</div>}
      {
        (cta || secondaryCta) && (
          <div class="hero-actions">
            {cta && (
              <a href={cta.href} class="btn btn-primary">
                {cta.text}
              </a>
            )}
            {secondaryCta && (
              <a href={secondaryCta.href} class="btn btn-outline">
                {secondaryCta.text}
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-20);
  }

  .hero-content {
    max-width: 48rem;
  }

  .hero-eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-5);
  }

  .hero-value-props {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    letter-spacing: 0.01em;
    margin-bottom: var(--space-6);
  }

  .hero-subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
    max-width: 42rem;
  }

  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-bg-alt);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    letter-spacing: 0.02em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: var(--space-12);
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
