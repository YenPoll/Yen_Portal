---
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/Card.astro";
import PageHeader from "@components/PageHeader.astro";
import { getCollection } from "astro:content";
import { SITE } from "@utils/constants";

const allCaseStudies = await getCollection("caseStudies");
const caseStudies = allCaseStudies.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Experience"
  description="Real project experience across PIM implementation, ERP transformation, channel operations, and LATAM market enablement — with measurable outcomes."
>
  <PageHeader
    id="case-studies-heading"
    eyebrow="Experience"
    title="Project Experience"
    subtitle="Real projects with documented scope, approach, and measurable outcomes. Each entry reflects direct execution responsibility — not advisory oversight."
  />

  <section class="section" aria-labelledby="case-studies-heading">
    <div class="container">
      {
        caseStudies.length > 0 ? (
          <div class="card-grid">
            {caseStudies.map((study) => (
              <Card
                title={study.data.title}
                description={study.data.description}
                href={`${SITE.base}/case-studies/${study.id}`}
                date={study.data.date}
                tags={study.data.tags}
                image={study.data.image}
              />
            ))}
          </div>
        ) : (
          <p class="empty-state">Case studies coming soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: var(--space-6);
  }

  .empty-state {
    padding: var(--space-12);
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }
</style>
