---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import Seo from "@components/Seo.astro";
import { SITE } from "@utils/constants";
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <Seo
    type="WebSite"
    data={{
      name: SITE.title,
      url: SITE.url,
      description: SITE.description,
      author: { "@type": "Person", name: SITE.author },
    }}
  />

  <!-- 1. Hero -->
  <Hero
    eyebrow="Latin America & Caribbean Markets"
    title="Global Business Operations & Market Enablement"
    valueProps={[
      "Customer Advocacy.",
      "Data-Driven Execution.",
      "Profitable Global Operations.",
    ]}
    subtitle="I help U.S.-based industrial, manufacturing, and technology companies grow international revenue, protect margins, and reduce operational cost by strengthening global commercial channels. I operate as the strategic bridge between headquarters, sales leadership, and international distributors — systems-driven and execution-focused."
    cta={{ text: "Schedule a Strategic Conversation", href: `${SITE.base}/contact` }}
    secondaryCta={{ text: "View Profit & Cost Impact", href: `${SITE.base}/impact` }}
  />

  <!-- 2. What I Deliver -->
  <section class="section-sm deliver-section" aria-labelledby="deliver-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="deliver-heading">What I Deliver</h2>
        <p class="section-lead">
          I operate as the right arm to Sales and Sales Leadership, ensuring commercial strategy turns into disciplined execution across global channels, systems, and markets.
        </p>
        <p class="section-body">
          My work sits at the intersection of sales operations, channel and distributor management, enterprise systems, customer advocacy, and long-term relationship discipline. Organizations engage me when execution gaps begin to impact revenue, margin, customer experience, and scalability.
        </p>
        <div class="deliver-grid">
          <div class="deliver-item">
            <h3>Sales Operations & Inside Sales</h3>
            <p>Execution support that lets sales teams focus on revenue generation while operations remain controlled and accurate.</p>
          </div>
          <div class="deliver-item">
            <h3>Channel & Distributor Operations</h3>
            <p>End-to-end management of international distributor relationships, compliance, and commercial performance.</p>
          </div>
          <div class="deliver-item">
            <h3>Systems, Data & Process Discipline</h3>
            <p>Enterprise-grade visibility and reporting that turns operational data into real-time business decisions.</p>
          </div>
          <div class="deliver-item">
            <h3>Customer Advocacy</h3>
            <p>First-point escalation trusted to resolve high-risk issues quickly, permanently, and without disrupting customer relationships.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Profit & Cost Impact Teaser -->
  <section class="section-sm impact-teaser" aria-labelledby="impact-heading">
    <div class="container">
      <h2 id="impact-heading" class="teaser-label">Profit & Cost Impact</h2>
      <div class="kpi-strip">
        <div class="kpi-tile">
          <span class="kpi-value">+5–15%</span>
          <span class="kpi-label">International channel revenue growth</span>
        </div>
        <div class="kpi-tile">
          <span class="kpi-value">$2M–$10M+</span>
          <span class="kpi-label">Incremental international revenue</span>
        </div>
        <div class="kpi-tile">
          <span class="kpi-value">+2–6%</span>
          <span class="kpi-label">Margin improvement</span>
        </div>
        <div class="kpi-tile">
          <span class="kpi-value">10–30%</span>
          <span class="kpi-label">Reduction in avoidable operational cost</span>
        </div>
        <div class="kpi-tile">
          <span class="kpi-value">15–35%</span>
          <span class="kpi-label">Faster order-to-cash cycles</span>
        </div>
      </div>
      <div class="teaser-cta">
        <a href={`${SITE.base}/impact`} class="btn btn-outline">
          Full Analysis & Data — Impact & Economics
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Systems & Data Execution -->
  <section class="section-sm" aria-labelledby="systems-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="systems-heading">Systems-Driven & Data-Led Execution</h2>
        <p class="section-lead">
          Global expansion succeeds or fails based on systems, data, and visibility. I operate with strong fluency across enterprise tools and platforms to ensure scalable execution.
        </p>
        <p class="section-body">
          Data is treated as an operational input, not a retrospective output. Every engagement is built on real-time visibility, structured reporting, and process discipline that survives leadership transitions and market changes.
        </p>
        <div class="systems-grid">
          <div class="system-item">
            <h3>CRM & Sales Operations</h3>
            <p>Pipeline support, forecasting visibility, and reporting discipline across Salesforce and equivalent platforms.</p>
          </div>
          <div class="system-item">
            <h3>ERP & Enterprise Systems</h3>
            <p>Global implementations, adoption, training, and process standardization across international affiliates.</p>
          </div>
          <div class="system-item">
            <h3>Sales & Operations Reporting</h3>
            <p>KPI design, dashboards, and performance tracking built for executive decision-making.</p>
          </div>
          <div class="system-item">
            <h3>Digital & Product Platforms</h3>
            <p>Product landing pages, global content updates, and UX alignment across multi-language environments.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Sales, Channel & Ops Leadership -->
  <section class="section-sm alt-section" aria-labelledby="sales-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="sales-heading">Sales, Channel & Operations Leadership</h2>
        <p class="section-lead">
          I support inside sales, field sales, and sales leadership as a central execution partner — enabling revenue growth without sacrificing operational control.
        </p>
        <p class="section-body">
          This includes complex deal and order support, pricing and commercial coordination, execution follow-through on leadership priorities, and operational data support for strategic decision-making. Sales teams focus on revenue generation. Execution remains controlled, accurate, and scalable.
        </p>
        <p class="section-body">
          I am frequently the first point of escalation between factory, sales teams, and international markets — trusted to resolve high-risk issues quickly, permanently, and without disrupting customer relationships.
        </p>
      </div>
    </div>
  </section>

  <!-- 6. Customer Advocacy & Product Marketing -->
  <section class="section-sm" aria-labelledby="cx-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="cx-heading">Customer Advocacy, UX & Product Marketing</h2>
        <p class="section-lead">
          Customer advocacy is embedded in my operating model — not treated as a support function, but as a revenue protection discipline.
        </p>
        <p class="section-body">
          As Product Marketing Manager at Wacker Neuson, I owned backend execution for global product landing pages and digital updates, supported global and LATAM product portfolios in multi-language environments, ensured UX clarity and data accuracy across markets, and acted as the voice of the customer to support product adaptations.
        </p>
        <p class="section-body">
          Strong UX and clear product information directly reduce support cost, adoption friction, and customer churn — outcomes that compound across global markets.
        </p>
      </div>
    </div>
  </section>

  <!-- 7. ERP & Global Transformation -->
  <section class="section-sm alt-section" aria-labelledby="erp-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="erp-heading">Enterprise Systems, ERP & Process Transformation</h2>
        <p class="section-lead">
          I played a central role in Wacker Neuson's global ERP implementation, acting as the operational bridge between IT business analysts and commercial affiliates across regions and languages.
        </p>
        <div class="two-col">
          <div>
            <h3>Scope & Execution</h3>
            <ul class="clean-list">
              <li>Business requirement translation across regions and languages</li>
              <li>User adoption, training, and change management</li>
              <li>Global process standardization and optimization</li>
              <li>Reporting and data visibility improvements</li>
              <li>Remote leadership with targeted on-site execution across Europe and Latin America</li>
            </ul>
          </div>
          <div>
            <h3>Outcomes</h3>
            <ul class="clean-list">
              <li>Higher system adoption across global affiliates</li>
              <li>Reduced manual work and duplication</li>
              <li>Improved sales visibility and execution consistency</li>
              <li>Lower operational cost and higher profitability</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Adaptability -->
  <section class="section-sm" aria-labelledby="adapt-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="adapt-heading">Adaptability: A Requirement for Global Success</h2>
        <p class="section-lead">
          Expansion into foreign markets requires continuous adaptation. I operate with flexibility across market dynamics, cultural and language differences, regulatory and operational constraints, and system and process maturity.
        </p>
        <p class="section-body">
          Adaptability is designed into how I operate — enabling companies to adjust quickly without losing control, data integrity, or margin. This is not a soft skill. It is an operational competency built across years of real-market execution in Latin America and the Caribbean.
        </p>
      </div>
    </div>
  </section>

  <!-- 9. Why LATAM & Caribbean -->
  <section class="section-sm alt-section" aria-labelledby="latam-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="latam-heading">Why Latin America & the Caribbean</h2>
        <p class="section-lead">
          Latin America and the Caribbean represent one of the most strategically under-leveraged growth regions for global companies. The opportunity is significant — and so is the cost of inaction.
        </p>
        <p class="section-body">
          Companies that delay expansion risk losing first-mover channel and distributor advantage, incurring higher future entry costs, being forced to compete on price rather than value, and becoming overdependent on saturated domestic markets.
        </p>
        <p class="section-body">
          Successful expansion requires local execution with global discipline. This is where I consistently deliver value.
        </p>
      </div>
    </div>
  </section>

  <!-- 10. Engagement Model -->
  <section class="section-sm" aria-labelledby="engage-heading">
    <div class="container">
      <div class="section-narrow">
        <h2 id="engage-heading">How I Engage</h2>
        <p class="section-lead">
          My operating model is designed for global reach with enterprise accountability — built for complexity, scale, and execution across international markets.
        </p>
        <div class="engage-grid">
          <div class="engage-item">
            <h3>Cross-Functional Leadership</h3>
            <p>I work directly alongside sales leadership, operations, IT, and finance — embedded in execution, not advising from a distance.</p>
          </div>
          <div class="engage-item">
            <h3>Global Market Reach</h3>
            <p>Proven delivery across Latin America, Caribbean, and multi-region environments — adapting execution to local market dynamics without losing global discipline.</p>
          </div>
          <div class="engage-item">
            <h3>Systems & Data Accountability</h3>
            <p>Every engagement is anchored in measurable KPIs, structured reporting, and process rigor that sustains results beyond the initial implementation.</p>
          </div>
          <div class="engage-item">
            <h3>Execution Ownership</h3>
            <p>I take direct ownership of outcomes — from order management and channel operations to ERP adoption and customer escalation resolution.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. Final CTA -->
  <section class="section cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-content">
        <h2 id="cta-heading">Let's Connect</h2>
        <p>
          If your organization needs a data-driven, systems-fluent global operator who can increase revenue, reduce cost, and execute profitably across international markets — without geographic limitations — let's start a conversation.
        </p>
        <a href={`${SITE.base}/contact`} class="btn btn-primary">
          Schedule a Strategic Conversation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Shared section typography */
  .section-narrow {
    max-width: 52rem;
  }

  .section-lead {
    font-size: var(--text-xl);
    color: var(--color-text);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .section-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  h2 {
    font-size: var(--text-3xl);
  }

  h3 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .alt-section {
    background-color: var(--color-bg-alt);
  }

  /* Deliver section */
  .deliver-section {
    background-color: var(--color-bg-alt);
  }

  .deliver-grid,
  .engage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  .deliver-item,
  .engage-item {
    padding: var(--space-6);
    background-color: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .deliver-item p,
  .engage-item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-2);
  }

  /* Impact teaser */
  .impact-teaser {
    border-top: var(--border-width) solid var(--color-border);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .teaser-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .kpi-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 13rem), 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .kpi-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .kpi-value {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1;
  }

  .kpi-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .teaser-cta {
    margin-top: var(--space-4);
  }

  /* Systems grid */
  .systems-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  .system-item {
    padding-top: var(--space-5);
    border-top: 2px solid var(--color-primary);
  }

  .system-item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-2);
  }

  /* ERP two-col */
  .two-col {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: var(--space-8);
    margin-top: var(--space-6);
  }

  .clean-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
  }

  .clean-list li {
    position: relative;
    padding-left: var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .clean-list li + li {
    margin-top: var(--space-2);
  }

  .clean-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: var(--weight-bold);
  }

  /* Final CTA */
  .cta-section {
    background-color: var(--color-bg-alt);
    text-align: center;
  }

  .cta-content {
    max-width: 40rem;
    margin-inline: auto;
  }

  .cta-content h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .cta-content p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }
</style>
