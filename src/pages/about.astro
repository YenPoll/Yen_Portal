---
import BaseLayout from "@layouts/BaseLayout.astro";
import Seo from "@components/Seo.astro";
import PageHeader from "@components/PageHeader.astro";
import { SITE } from "@utils/constants";
---

<BaseLayout
  title="About"
  description="Global Business Operations & Market Enablement leader specializing in Latin America & Caribbean markets across industrial, manufacturing, and technology sectors."
>
  <Seo
    type="Person"
    data={{
      name: SITE.author,
      url: `${SITE.url}/about`,
      description:
        "Global Business Operations & Market Enablement leader. Latin America & Caribbean specialist.",
      jobTitle:
        "Global Business Operations & Market Enablement Leader",
    }}
  />

  <PageHeader
    id="about-heading"
    eyebrow="About"
    title="Global Business Operations Leader"
    subtitle="I am a Global Business Operations & Market Enablement leader specializing in Latin America and Caribbean markets, with deep experience across industrial, manufacturing, and technology sectors. I serve as the strategic and operational bridge between headquarters, sales leadership, and international channels, bringing enterprise grade accountability to every market I support."
  />

  <section class="section" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-content">

        <div class="about-section">
          <h2>Professional Background</h2>
          <p>
            My career has been built at the intersection of sales operations, channel management, enterprise systems, and international market development. I have operated across complex, multi region environments, managing distributor relationships, driving ERP implementations, supporting sales leadership, and building the operational infrastructure that allows global commercial strategies to execute with precision.
          </p>
          <p>
            At Wacker Neuson, I served as Product Marketing Manager with responsibility for global product landing pages, multi language digital content, and LATAM product portfolio support. I also played a central role in the company's global ERP implementation, acting as the bridge between IT business analysts and commercial affiliates across Europe and Latin America.
          </p>
        </div>

        <div class="about-section">
          <h2>Core Differentiators</h2>
          <div class="diff-grid">
            <div class="diff-item">
              <h3>Customer Advocacy</h3>
              <p>I am frequently the first point of escalation between factory, sales teams, and international markets. Trusted to resolve high risk issues quickly, permanently, and without disrupting customer relationships.</p>
            </div>
            <div class="diff-item">
              <h3>Systems & Data Discipline</h3>
              <p>Strong fluency across CRM, ERP, and enterprise reporting platforms. Data is treated as an operational input, not a retrospective output, enabling real time visibility and decision making.</p>
            </div>
            <div class="diff-item">
              <h3>Adaptability</h3>
              <p>Built in flexibility across market dynamics, cultural and language differences, regulatory constraints, and system maturity levels. This is an operational competency, not a soft skill.</p>
            </div>
            <div class="diff-item">
              <h3>Profit & Cost Impact</h3>
              <p>Every initiative is anchored in commercial outcomes: revenue growth, margin improvement, and cost reduction that are measurable, reportable, and repeatable.</p>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>Areas of Expertise</h2>
          <div class="expertise-grid">
            <div class="expertise-category">
              <h3>Global Business Operations</h3>
              <ul>
                <li>Channel & distributor management</li>
                <li>Sales operations & inside sales support</li>
                <li>Order management & logistics</li>
                <li>Cross functional execution</li>
              </ul>
            </div>
            <div class="expertise-category">
              <h3>Enterprise Systems</h3>
              <ul>
                <li>ERP implementation & adoption</li>
                <li>CRM & pipeline management (Salesforce)</li>
                <li>KPIs, dashboards & reporting</li>
                <li>Process standardization</li>
              </ul>
            </div>
            <div class="expertise-category">
              <h3>Market Enablement</h3>
              <ul>
                <li>Latin America & Caribbean expansion</li>
                <li>Distributor network development</li>
                <li>Product marketing & UX alignment</li>
                <li>Multi language market execution</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>Operating Model</h2>
          <p>
            I bring a global operating perspective with proven execution across international markets. My work is structured around direct ownership of outcomes, from channel operations and sales enablement to ERP implementation and customer advocacy, with accountability at every stage.
          </p>
          <p>
            I work embedded with sales leadership, operations, and IT, with direct, hands on accountability for results at every stage of execution.
          </p>
        </div>

        <div class="about-section">
          <h2>Industries</h2>
          <div class="industry-list">
            <span class="industry-tag">Industrial</span>
            <span class="industry-tag">Manufacturing</span>
            <span class="industry-tag">Technology</span>
          </div>
        </div>

        <div class="about-cta">
          <p>I'm actively exploring full time operations roles where this experience can drive similar results in house.</p>
          <a href={`${SITE.base}/contact`} class="btn btn-primary">
            Let's Connect
          </a>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-content {
    max-width: 52rem;
  }

  .about-section {
    margin-bottom: var(--space-12);
  }

  .about-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .about-section p {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  h3 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  /* Differentiators */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: var(--space-6);
    margin-top: var(--space-5);
  }

  .diff-item {
    padding: var(--space-5);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .diff-item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* Expertise */
  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: var(--space-6);
    margin-top: var(--space-5);
  }

  .expertise-category {
    padding: var(--space-5);
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .expertise-category ul {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0;
  }

  .expertise-category li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-1) 0;
  }

  .expertise-category li + li {
    margin-top: 0;
  }

  /* Industries */
  .industry-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .industry-tag {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-bg-alt);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  /* CTA */
  .about-cta {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: var(--border-width) solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .about-cta p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin: 0;
  }
</style>
