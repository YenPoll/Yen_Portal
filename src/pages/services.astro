---
import BaseLayout from "@layouts/BaseLayout.astro";
import { SITE } from "@utils/constants";
---

<BaseLayout
  title="Core Expertise"
  description="Global Business Operations & Market Enablement services — channel operations, sales enablement, ERP transformation, product marketing, and LATAM market expansion."
>
  <section class="section" aria-labelledby="services-heading">
    <div class="container">
      <div class="services-header">
        <p class="services-eyebrow">Core Expertise</p>
        <h1 id="services-heading">What I Deliver</h1>
        <p class="services-intro">
          I operate as the right arm to Sales and Sales Leadership — ensuring commercial strategy turns into disciplined execution across global channels, systems, and markets.
        </p>
      </div>

      <div class="services-grid">

        <div class="service-card">
          <h2>Global Channel & Distributor Operations</h2>
          <p class="service-desc">
            End-to-end management of international distributor relationships, compliance, and commercial performance. I build the operational infrastructure that ensures channel partners execute at the standards headquarters requires.
          </p>
          <ul class="service-features">
            <li>Distributor onboarding, performance management, and compliance</li>
            <li>Order management, logistics, and dropshipment coordination</li>
            <li>Commercial escalation resolution — factory to market</li>
            <li>Latin America & Caribbean channel development and expansion</li>
          </ul>
        </div>

        <div class="service-card">
          <h2>Sales Operations & Inside Sales Enablement</h2>
          <p class="service-desc">
            Execution support that lets field sales and leadership focus on revenue generation while operations remain controlled, accurate, and scalable.
          </p>
          <ul class="service-features">
            <li>Complex deal and order management support</li>
            <li>Pricing, commercial coordination, and quoting accuracy</li>
            <li>CRM discipline, pipeline visibility, and forecasting support</li>
            <li>KPI reporting and performance tracking for sales leadership</li>
          </ul>
        </div>

        <div class="service-card">
          <h2>Enterprise Systems & ERP Transformation</h2>
          <p class="service-desc">
            I bridge the gap between IT business analysts and commercial teams — translating business requirements, driving user adoption, and ensuring ERP implementations deliver on their commercial promise.
          </p>
          <ul class="service-features">
            <li>Business requirement translation across regions and languages</li>
            <li>User adoption, training, and change management programs</li>
            <li>Global process standardization and optimization</li>
            <li>Reporting, data visibility, and dashboard design</li>
          </ul>
        </div>

        <div class="service-card">
          <h2>LATAM & Caribbean Market Enablement</h2>
          <p class="service-desc">
            Structured market entry and commercial execution for companies expanding into Latin America and Caribbean markets. First-mover advantage requires operational infrastructure from day one.
          </p>
          <ul class="service-features">
            <li>Market entry strategy and distributor network development</li>
            <li>Regulatory, cultural, and operational adaptation</li>
            <li>Local execution with global discipline and reporting standards</li>
            <li>Ongoing market management and relationship development</li>
          </ul>
        </div>

        <div class="service-card">
          <h2>Customer Advocacy & CX Operations</h2>
          <p class="service-desc">
            Customer advocacy embedded as an operational discipline — not a support function. I own escalation resolution, retention risk, and the customer experience that protects margin and long-term relationships.
          </p>
          <ul class="service-features">
            <li>First-point escalation management between factory, sales, and market</li>
            <li>Customer experience audits and improvement programs</li>
            <li>Voice of customer to product, marketing, and operations</li>
            <li>Retention-focused relationship management</li>
          </ul>
        </div>

        <div class="service-card">
          <h2>Product Marketing & Digital Execution</h2>
          <p class="service-desc">
            Global product content, landing page execution, and UX alignment across multi-language markets — ensuring customers find accurate, clear information that reduces friction and supports commercial conversion.
          </p>
          <ul class="service-features">
            <li>Global and LATAM product portfolio content management</li>
            <li>Digital product landing pages and UX alignment</li>
            <li>Multi-language content accuracy and consistency</li>
            <li>Product information management across markets</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Engagement Model -->
  <section class="section-sm engagement-section" aria-labelledby="engage-heading">
    <div class="container">
      <h2 id="engage-heading" class="section-heading">How I Work</h2>
      <p class="section-body">
        My work is structured to deliver measurable commercial outcomes — with direct ownership of execution across channel operations, sales enablement, enterprise systems, and international market development.
      </p>
      <div class="engage-grid">
        <div class="engage-option">
          <span class="engage-number">01</span>
          <h3>Cross-Functional Leadership</h3>
          <p>Embedded with sales leadership, operations, IT, and finance — aligned across departments to move strategy into disciplined execution.</p>
        </div>
        <div class="engage-option">
          <span class="engage-number">02</span>
          <h3>International Market Execution</h3>
          <p>Direct operational ownership across Latin America and Caribbean markets — channel management, distributor relationships, and commercial accountability.</p>
        </div>
        <div class="engage-option">
          <span class="engage-number">03</span>
          <h3>Systems & Process Transformation</h3>
          <p>ERP implementation, CRM discipline, and reporting infrastructure — built for scalable, repeatable global operations.</p>
        </div>
        <div class="engage-option">
          <span class="engage-number">04</span>
          <h3>Revenue & Margin Accountability</h3>
          <p>Every area of work — channel ops, customer advocacy, sales enablement — is anchored in profit impact and cost discipline.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section" aria-labelledby="services-cta-heading">
    <div class="container">
      <div class="cta-content">
        <h2 id="services-cta-heading">Let's Connect</h2>
        <p>
          I'm actively exploring full-time operations leadership roles where this experience can drive similar results in-house. Reach out to start a conversation.
        </p>
        <a href={`${SITE.base}/contact`} class="btn btn-primary">
          Contact Me
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .services-header {
    max-width: 52rem;
    margin-bottom: var(--space-12);
  }

  .services-eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .services-header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .services-intro {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 28rem), 1fr));
    gap: var(--space-6);
  }

  .service-card {
    padding: var(--space-8);
    background-color: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .service-card h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .service-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: var(--border-width) solid var(--color-border);
    padding-top: var(--space-5);
  }

  .service-features li {
    position: relative;
    padding-left: var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .service-features li + li {
    margin-top: var(--space-2);
  }

  .service-features li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: var(--weight-bold);
  }

  /* Engagement section */
  .engagement-section {
    background-color: var(--color-bg-alt);
  }

  .section-heading {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .section-body {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 48rem;
    margin-bottom: var(--space-8);
  }

  .engage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 14rem), 1fr));
    gap: var(--space-6);
  }

  .engage-option {
    padding: var(--space-6);
  }

  .engage-number {
    display: block;
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: var(--space-3);
  }

  .engage-option h3 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .engage-option p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  /* CTA */
  .cta-section {
    text-align: center;
  }

  .cta-content {
    max-width: 40rem;
    margin-inline: auto;
  }

  .cta-content h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .cta-content p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }
</style>
